# Copy this file to .env and fill in your values.

# --- Security ---
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here

# --- Database ---
# Leave DATABASE_URL blank to auto-build from the fields below.
# Set POSTGRES_SERVER to use PostgreSQL; leave blank to fall back to SQLite.
DATABASE_URL=
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_DB=portfolio_db

# --- CORS ---
# Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Market Data APIs ---
# Get a free key at https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=

# Get a free key at https://finnhub.io/register
FINNHUB_API_KEY=

# --- AI Explanations (optional) ---
# Get a free key at https://console.groq.com
GROQ_API_KEY=

# --- Email Notifications (optional) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
